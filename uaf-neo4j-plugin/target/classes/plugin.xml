<?xml version="1.0" encoding="UTF-8"?>
<!--
    MagicDraw / MSOSA 2022x plugin descriptor.
    Deploy the entire uaf-neo4j-plugin/ folder into:
        <MSOSA_HOME>/plugins/
    then restart MSOSA.
-->
<plugin id="com.uaf.neo4j.plugin"
        name="UAF Neo4j Export Plugin"
        version="1.0.0"
        provider-name="UAF Tools"
        class="com.uaf.neo4j.plugin.UAFNeo4jPlugin">

    <requires>
        <api version="1.0"/>
    </requires>

    <runtime>
        <library name="uaf-neo4j-plugin-1.0.0.jar"/>
    </runtime>
</plugin>
